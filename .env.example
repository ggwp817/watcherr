# Timezone
TZ=UTC

# JWT signing secret - MUST be changed for production
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-to-a-long-random-string

# Default admin account seeded on first boot (only used if no admin exists)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=changeme123

# Port the app listens on (default 9494)
PORT=9494

# Note: Sonarr, Radarr, Jellyfin, TMDB, and Bazarr API keys are configured
# at runtime via the Admin → System page. They are NOT environment variables.
